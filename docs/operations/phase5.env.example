APP_ENV=production
SECRET_KEY=replace-with-a-long-random-secret

# Phase 5 target database
DATABASE_URL=postgresql://postgres:replace-password@127.0.0.1:5432/rental_rebuild
APP_HOST=127.0.0.1
APP_PORT=8000

# Connection pool
DB_POOL_SIZE=5
DB_POOL_RECYCLE=3600
DB_POOL_TIMEOUT=30

# Optional PostgreSQL tooling overrides
PG_DUMP_BIN=pg_dump
PSQL_BIN=psql

# Evidence / logs (operator may customize per rehearsal)
LINE_WEBHOOK_AUDIT_LOG=

# Optional integrations
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=
OCR_PROVIDER=
OCR_API_KEY=
